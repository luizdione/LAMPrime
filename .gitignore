# Calculation/tool repository — neutral patterns.

# Local working material (kept out of the public repository)
/src/
/build/
/figuras/

# Downloaded data (reproduce via scripts; do not version)
/data/*
!/data/.gitkeep

# Large calculation outputs
/results/*
!/results/.gitkeep

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
env/

