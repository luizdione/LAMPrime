*.aux
*.toc
*.out
*.log
*.docx
*.tex

# Large bioinformatics files
*.vcf
*.vcf.gz
*.bam
*.bai
*.fa
*.fasta
*.fai

# OS / editors
.DS_Store
Thumbs.db
desktop.ini
.vscode/
